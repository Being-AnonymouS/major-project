{
  "version": 2,
  "framework": "vite",
  "installCommand": "npm install --include=dev",
  "buildCommand": "npm run vercel:build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api$",
      "dest": "/api/index"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/[...route]"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
