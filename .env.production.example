# Production Environment Variables

# BACKEND (.env on Render)
# ========================
PORT=5000
NODE_ENV=production
DATABASE_URL=postgresql://user:password@host:port/database
JWT_SECRET=your-production-jwt-secret-min-32-characters
JWT_REFRESH_SECRET=your-production-refresh-secret-min-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
BOOTSTRAP_ADMIN_EMAIL=admin@mentorconnect.com
BOOTSTRAP_ADMIN_NAME=Administrator
BOOTSTRAP_ADMIN_PASSWORD=change-this-immediately
BOOTSTRAP_INCLUDE_DEMO_USERS=true
BOOTSTRAP_MENTOR_EMAIL=mentor@mentorconnect.com
BOOTSTRAP_MENTOR_NAME=Mentor Demo
BOOTSTRAP_MENTOR_PASSWORD=change-this-immediately
BOOTSTRAP_MENTEE_EMAIL=mentee@mentorconnect.com
BOOTSTRAP_MENTEE_NAME=Mentee Demo
BOOTSTRAP_MENTEE_PASSWORD=change-this-immediately

# FRONTEND (.env.production on Vercel)
# ====================================
# Optional when using root-level vercel.json rewrites.
# Set these only if you need to bypass rewrites and call backend directly.
VITE_API_URL=https://your-backend.onrender.com/api
VITE_SOCKET_URL=https://your-backend.onrender.com
VITE_ENABLE_REALTIME=false
